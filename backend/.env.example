# Database (optional — default matches docker compose)
# DATABASE_URL=postgresql+psycopg://convertreino:convertreino@localhost:5432/convertreino

# JWT (required for OAuth)
JWT_SECRET=your-jwt-secret-at-least-32-characters
# JWT_EXPIRES_MINUTES=60

# Strava OAuth (required for auth endpoints)
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_REDIRECT_URI=http://localhost:8000/auth/strava/callback
# STRAVA_MOBILE_REDIRECT_URI=convertreino://oauth/callback

# OpenAI chat (required for /chat/messages when LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# Groq Cloud (required for /chat/messages when LLM_PROVIDER=groq)
# LLM_PROVIDER=openai
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile

# CHAT_MAX_TOOL_ITERATIONS=5

# Strava webhooks (optional)
# STRAVA_WEBHOOK_VERIFY_TOKEN=
# STRAVA_WEBHOOK_CALLBACK_URL=
